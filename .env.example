# Copy this file to .env.local (gitignored by Vite's default .gitignore)
# and fill in a real PostHog project API key to enable analytics locally.
# Without VITE_POSTHOG_KEY set, the app runs exactly as before -- see
# src/services/analytics.js and docs/ANALYTICS.md.

# PostHog project API key (Project Settings -> Project API Key). This is the
# public "write-only" key, safe to ship in a client bundle.
VITE_POSTHOG_KEY=

# PostHog Cloud region host. Use https://us.i.posthog.com (default) or
# https://eu.i.posthog.com depending on which region the project was
# created in.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# For the deployed site (Cloudflare Pages), set VITE_POSTHOG_KEY /
# VITE_POSTHOG_HOST as build-time environment variables in the Pages
# project settings instead of committing them here.
#
# docs/ANALYTICS.md recommends creating TWO PostHog projects -- "Dot Hopper"
# (production key, set only in Cloudflare Pages) and "Dot Hopper Dev" (this
# key, set only in .env.local) -- so local testing never touches production
# dashboards.
